---
interface Props {
  title: string;
  showBack?: boolean;
}
const { title, showBack = false } = Astro.props;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="VetAnchor - 獣医師・愛玩動物看護師・学生のためのクエスト型求人プラットフォーム" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <div class="ocean-bg">

    <header class="site-header">
      <div>
        {showBack ? (
          <a href="/" class="back-button">◀ ギルドロビー</a>
        ) : (
          <div class="header-logo">VetAnchor</div>
        )}
      </div>
      <div class="player-status">
        <div class="status-item">
          <span class="status-label">Hunter</span>
          <span class="status-value" style="font-size: 0.8rem;">ゲストハンター</span>
        </div>
        <div class="status-divider"></div>
        <div class="status-item">
          <span class="status-label">Rank</span>
          <span class="status-value" style="color: var(--ocean-pale);">HR 1</span>
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <p>&copy; 2026 VetAnchor &mdash; 動物医療ギルドボード</p>
      <p style="margin-top: 6px;">※ これはデモサイトです。実際の求人情報ではありません。</p>
    </footer>

  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
