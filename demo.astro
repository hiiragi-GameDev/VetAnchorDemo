export default function App() {
  const [acceptedQuests, setAcceptedQuests] = useState([]);
  const [currentView, setCurrentView] = useState('home'); // 'home' | 'board'
  const [activeCategory, setActiveCategory] = useState(null);
  const [showAcceptAnimation, setShowAcceptAnimation] = useState(false);

  // クエスト受注処理
  const handleAccept = (id) => {
    if (!acceptedQuests.includes(id)) {
      setShowAcceptAnimation(true);
      setTimeout(() => {
        setAcceptedQuests([...acceptedQuests, id]);
        setShowAcceptAnimation(false);
      }, 1500); // 1.5秒間アニメーションを表示
    }
  };

  // 掲示板を開く
  const handleOpenBoard = (category) => {
    setActiveCategory(category);
    setCurrentView('board');
    window.scrollTo(0, 0);
  };

  // ホームに戻る
  const handleBackToHome = () => {
    setCurrentView('home');
    setActiveCategory(null);
    window.scrollTo(0, 0);
  };

  // 難易度の星
  const renderStars = (difficulty) => {
    const maxStars = 10;
    let stars = '';
    for (let i = 0; i < maxStars; i++) {
      stars += i < difficulty ? '★' : '☆';
    }
    return stars;
  };

  // フィルター処理
  const filteredQuests = questData.filter(quest => {
    if (!activeCategory) return false;
    return quest.category === activeCategory;
  });

  return (
    <>
      <style>{styles}</style>
      <div className="ocean-bg min-h-screen font-sans relative">
        
        {/* 受注完了の全画面演出 */}
        {showAcceptAnimation && (
          <div className="accept-overlay">
            <div className="accept-stamp-huge">
              QUEST<br/>ACCEPTED
            </div>
          </div>
        )}

        {/* ヘッダー部分 */}
        <header className="bg-[#010812] border-b-4 border-[#0288d1] py-3 px-4 md:px-6 shadow-xl sticky top-0 z-40 flex justify-between items-center">
          
          {/* 左側：戻るボタン または ミニロゴ */}
          <div>
            {currentView === 'board' ? (
              <button 
                onClick={handleBackToHome}
                className="bg-[#01579b] text-[#e1f5fe] px-4 py-2 rounded font-bold border-2 border-[#0288d1] hover:bg-[#0277bd] transition-colors flex items-center shadow-lg text-sm md:text-base"
              >
                ◀ ギルドロビー
              </button>
            ) : (
              <div className="text-[#0288d1] font-bold font-['Kaisei_Decol'] text-xl hidden md:block">
                Veterinary Guild
              </div>
            )}
          </div>

          {/* 右側：ハンターステータス */}
          <div className="player-status">
            <div className="status-item">
              <span className="status-label">HUNTER</span>
              <span className="status-value text-xs md:text-base">ゲストハンター</span>
            </div>
            <div className="w-px h-8 bg-[#0288d1]"></div>
            <div className="status-item">
              <span className="status-label">RANK</span>
              <span className="status-value text-[#81d4fa]">HR 1</span>
            </div>
            <div className="w-px h-8 bg-[#0288d1] hidden md:block"></div>
            <div className="status-item hidden md:flex">
              <span className="status-label">QUESTS</span>
              <span className="status-value">{acceptedQuests.length}</span>
            </div>
          </div>
        </header>

        {/* ホーム画面（掲示板選択ロビー） */}
        {currentView === 'home' && (
          <main className="max-w-5xl mx-auto px-4 py-12 flex flex-col items-center min-h-[85vh]">
            
            {/* 巨大なロゴ */}
            <div className="mb-12 text-center animate-[fadeIn_1s_ease-in]">
              <h1 className="hero-title">VetAnchor</h1>
              <p className="text-[#81d4fa] font-bold tracking-widest text-lg md:text-xl font-['Yuji_Syuku'] mt-2">
                〜 全動物関連ギルドボード 〜
              </p>
            </div>
            
            <div className="text-[#b3e5fc] text-center mb-10 font-bold bg-[#010812] bg-opacity-70 py-3 px-6 rounded-lg border border-[#0288d1] max-w-2xl shadow-lg">
              「よく来たな。動物病院から一般企業、行政まで、あらゆる動物関連の依頼が集まっている。自分の職種の掲示板を見るがいい。」
            </div>
            
            <div className="grid grid-cols-1 md:grid-cols-3 gap-8 w-full max-w-4xl">
              
              {/* 獣医師ボード */}
              <div className="signboard flex flex-col items-center justify-center py-10 px-4" onClick={() => handleOpenBoard('獣医師')}>
                <div className="chain chain-left"></div>
                <div className="chain chain-right"></div>
                <div className="text-5xl mb-4 drop-shadow-md">🩺</div>
                <h3 className="text-3xl font-bold text-[#01579b] mb-2">獣医師</h3>
                <div className="w-16 h-1 bg-[#0288d1] mb-4"></div>
                <p className="text-[#004d40] font-bold text-center text-sm md:text-base leading-relaxed">
                  臨床、行政、企業案件まで<br/>高度な資格を活かす任務だ。
                </p>
              </div>

              {/* 愛玩動物看護師ボード */}
              <div className="signboard flex flex-col items-center justify-center py-10 px-4" onClick={() => handleOpenBoard('愛玩動物看護師')}>
                <div className="chain chain-left"></div>
                <div className="chain chain-right"></div>
                <div className="text-5xl mb-4 drop-shadow-md">💉</div>
                <h3 className="text-3xl font-bold text-[#01579b] mb-2">愛玩動物看護師</h3>
                <div className="w-16 h-1 bg-[#0288d1] mb-4"></div>
                <p className="text-[#004d40] font-bold text-center text-sm md:text-base leading-relaxed">
                  医療現場の要から<br/>保護施設の護衛まで幅広いぞ。
                </p>
              </div>

              {/* 学生ボード */}
              <div className="signboard flex flex-col items-center justify-center py-10 px-4" onClick={() => handleOpenBoard('学生')}>
                <div className="chain chain-left"></div>
                <div className="chain chain-right"></div>
                <div className="text-5xl mb-4 drop-shadow-md">🐾</div>
                <h3 className="text-3xl font-bold text-[#01579b] mb-2">学生ハンター</h3>
                <div className="w-16 h-1 bg-[#0288d1] mb-4"></div>
                <p className="text-[#004d40] font-bold text-center text-sm md:text-base leading-relaxed">
                  動物園やイベントなど<br/>次世代を担う君向けの任務だ。
                </p>
              </div>

            </div>
          </main>
        )}

        {/* クエストボード（リスト画面） */}
        {currentView === 'board' && (
          <main className="max-w-4xl mx-auto px-4 py-8">
            <div className="mb-8 text-center">
              <h2 className="quest-title text-3xl md:text-4xl text-[#e1f5fe] inline-block border-b-2 border-dashed border-[#0288d1] pb-2 px-8 bg-[#010812] bg-opacity-70 rounded-lg shadow-lg">
                【 {activeCategory} 】 掲示板
              </h2>
            </div>

            <div className="space-y-8">
              {filteredQuests.map((quest) => (
                <div key={quest.id} className="parchment-card w-full rounded-sm">
                  
                  {/* 受注済スタンプ（カード内） */}
                  {acceptedQuests.includes(quest.id) && (
                    <div className="quest-stamp">QUEST<br/>ACCEPTED</div>
                  )}

                  <div className="parchment-inner-border">
                    {/* 四隅の飾り */}
                    <div className="corner-ornament corner-tl"></div>
                    <div className="corner-ornament corner-tr"></div>
                    <div className="corner-ornament corner-bl"></div>
                    <div className="corner-ornament corner-br"></div>

                    {/* タイトルエリア */}
                    <div className="text-center mb-6 mt-2 border-b-2 border-dashed border-[#8b5a2b] pb-4 relative">
                      {/* 分野バッジ */}
                      <div className="absolute top-0 left-0 md:left-2">
                        <span className={`field-badge ${fieldConfig[quest.field] || 'field-other'}`}>
                          {quest.field}
                        </span>
                      </div>
                      
                      <h2 className="quest-title text-2xl md:text-3xl mb-2 tracking-widest mt-6 md:mt-0">{quest.type}</h2>
                      <p className="quest-title text-xl md:text-2xl">〜 {quest.title} 〜</p>
                    </div>
                    
                    {/* 詳細情報エリア */}
                    <div className="flex flex-col md:flex-row gap-6 md:gap-12 text-[15px] md:text-[16px] font-bold leading-relaxed">
                      
                      {/* 左カラム */}
                      <div className="flex-1 space-y-3">
                        <div className="flex items-start">
                          <span className="w-24 shrink-0 text-[#5c3a21]">難易度：</span>
                          <span className="tracking-widest text-[#2d1a0d]">{renderStars(quest.difficulty)}</span>
                        </div>
                        <div className="flex items-start">
                          <span className="w-24 shrink-0 text-[#5c3a21]">制限時間：</span>
                          <span>〜 {quest.deadline}</span>
                        </div>
                        <div className="flex items-start">
                          <span className="w-24 shrink-0 text-[#5c3a21]">目的地：</span>
                          <span>{quest.location}</span>
                        </div>
                        <div className="flex items-start">
                          <span className="w-24 shrink-0 text-[#5c3a21]">報酬：</span>
                          <span className="text-[#8b0000]">{quest.reward}</span>
                        </div>
                      </div>
                      
                      {/* 右カラム */}
                      <div className="flex-1 space-y-5">
                        <div>
                          <span className="text-[#5c3a21] block mb-1">達成条件：</span>
                          <ul className="space-y-1 ml-2">
                            {quest.conditions.map(c => <li key={c}>{c}</li>)}
                          </ul>
                        </div>
                        <div>
                          <span className="text-[#5c3a21] block mb-1">依頼者コメント：</span>
                          <p className="ml-2 bg-[#d8c2a4] bg-opacity-40 p-3 rounded border border-[#c4a98a]">
                            {quest.comment}
                          </p>
                        </div>
                      </div>
                    </div>
                    
                    {/* アクションボタンエリア */}
                    <div className="mt-8 text-center pt-4">
                       <button 
                         className="guild-button px-10 py-4 font-bold rounded text-lg tracking-widest w-full md:w-auto min-w-[300px]"
                         onClick={() => handleAccept(quest.id)}
                         disabled={acceptedQuests.includes(quest.id)}
                       >
                         {acceptedQuests.includes(quest.id) ? '受注済み' : 'クエストを受注する'}
                       </button>
                    </div>

                  </div>
                </div>
              ))}
            </div>
          </main>
        )}
      </div>
    </>
  );
}